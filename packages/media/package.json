{
    "name": "@orch/media",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "dev": "tsc -w",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@orch/daemon": "workspace:*",
        "@orch/db-manager": "workspace:*",
        "@orch/shared": "workspace:*",
        "zod": "^3.24.2"
    },
    "devDependencies": {
        "@types/node": "^25.3.0",
        "typescript": "^5.7.3"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts"
        }
    }
