{
    "name": "@orch/db-manager",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc --build",
        "clean": "tsc --build --clean"
    },
    "dependencies": {
        "@orch/vault": "workspace:*",
        "better-sqlite3-multiple-ciphers": "^11.5.0"
    },
    "devDependencies": {
        "@orch/daemon": "workspace:*",
        "@orch/shared": "workspace:*"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts"
        }
    }
}
