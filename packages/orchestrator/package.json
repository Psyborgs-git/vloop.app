{
    "name": "@orch/orchestrator",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/main.js",
    "scripts": {
        "predev": "pnpm --filter @orch/terminal build",
        "build": "tsc --build",
        "dev": "ORCH_DB_PASSPHRASE=dev ORCH_VAULT_PASSPHRASE=dev tsx src/main.ts",
        "start": "node dist/main.js",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@orch/ai-agent": "workspace:*",
        "@orch/auth": "workspace:*",
        "@orch/container": "workspace:*",
        "@orch/daemon": "workspace:*",
        "@orch/db-manager": "workspace:*",
        "@orch/media": "workspace:*",
        "@orch/process": "workspace:*",
        "@orch/shared": "workspace:*",
        "@orch/terminal": "workspace:*",
        "@orch/vault": "workspace:*",
        "express": "^5.2.1"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "tsx": "^4.21.0",
        "typescript": "^5.7.0"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    }
}
