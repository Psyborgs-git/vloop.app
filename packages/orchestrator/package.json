{
    "name": "@orch/orchestrator",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "main": "./dist/main.js",
    "scripts": {
        "predev": "pnpm -r --filter @orch/* build",
        "build": "tsc --build",
        "dev": "ORCH_DB_PASSPHRASE=dev ORCH_VAULT_PASSPHRASE=dev pnpm exec tsx src/main.ts",
        "start": "node dist/main.js",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@orch/ai-agent": "workspace:*",
        "@orch/auth": "workspace:*",
        "@orch/container": "workspace:*",
        "@orch/daemon": "workspace:*",
        "@orch/db-manager": "workspace:*",
        "@orch/event-contracts": "workspace:*",
        "@orch/gateway": "workspace:*",
        "@orch/mcp-server": "workspace:*",
        "@orch/media": "workspace:*",
        "@orch/plugin-manager": "workspace:*",
        "@orch/process": "workspace:*",
        "@orch/rbac": "workspace:*",
        "@orch/shared": "workspace:*",
        "@orch/terminal": "workspace:*",
        "@orch/vault": "workspace:*",
        "@types/diff": "^8.0.0",
        "diff": "^8.0.3",
        "express": "^5.2.1",
        "ioredis": "^5.6.1",
        "ws": "^8.19.0"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/ws": "^8.18.1",
        "tsx": "^4.21.0",
        "typescript": "^5.7.0"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts"
        }
    }
}
