{
    "name": "@orch/ai-agent",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "scripts": {
        "build": "tsc --build",
        "clean": "tsc --build --clean"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1",
        "@types/diff": "^8.0.0",
        "drizzle-orm": "^0.44.7",
        "diff": "^8.0.3",
        "express": "^5.2.1",
        "google-diff-match-patch": "^2.0.0",
        "ollama": "^0.6.3",
        "playwright": "^1.58.2",
        "ws": "^8.19.0",
        "zod": "~4.3.6",
        "@jaex/dstsx": "^0.1.21"
    },
    "devDependencies": {
        "@orch/container": "workspace:*",
        "@orch/daemon": "workspace:*",
        "@orch/event-contracts": "workspace:*",
        "@orch/process": "workspace:*",
        "@orch/shared": "workspace:*"
