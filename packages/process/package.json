{
    "name": "@orch/process",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts"
        }
    },
    "scripts": {
        "build": "tsc --build",
        "clean": "rm -rf dist tsconfig.tsbuildinfo"
    },
    "dependencies": {
        "@orch/shared": "workspace:*",
        "@orch/daemon": "workspace:*",
        "cron-parser": "^5.0.3",
        "tree-kill": "^1.2.2"
    },
    "devDependencies": {
        "typescript": "^5.7.3"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    }
}
