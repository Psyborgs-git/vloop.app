{
    "name": "@orch/vault",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts"
        }
    },
    "scripts": {
        "build": "tsc --build",
        "clean": "rm -rf dist",
        "test": "vitest run"
    },
    "dependencies": {
        "@orch/shared": "workspace:*",
        "@orch/daemon": "workspace:*",
        "argon2": "^0.41.0",
        "drizzle-orm": "^0.44.7"
    },
    "devDependencies": {
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    }
}
