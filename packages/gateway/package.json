{
    "name": "@orch/gateway",
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        },
        "./*": {
            "import": "./dist/*.js",
            "types": "./dist/*.d.ts"
        }
    },
    "scripts": {
        "build": "tsc --build",
        "clean": "rm -rf dist",
        "test": "vitest run"
    },
    "dependencies": {
        "@orch/event-contracts": "workspace:*",
        "ioredis": "^5.4.0",
        "minimatch": "^10.2.3",
        "ws": "^8.18.0"
    },
    "devDependencies": {
        "@types/ws": "^8.5.13",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    },
    "files": [
        "dist"
    ],
    "publishConfig": {
        "access": "public"
    }
}
