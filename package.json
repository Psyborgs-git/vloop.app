{
    "name": "orchestrator",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Host-level orchestrator daemon — manages containers, processes, AI agents, databases, and device access via secure WebSocket API.",
    "scripts": {
        "prepare": "node scripts/fix-pty-permissions.mjs 2>/dev/null || true",
        "build": "tsc --build",
        "dev": "pnpm --filter @orch/orchestrator dev",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:integration": "vitest run --project integration",
        "lint": "eslint packages/",
        "clean": "tsc --build --clean && rm -rf packages/*/tsconfig.tsbuildinfo"
    },
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=10.0.0"
    },
    "packageManager": "pnpm@10.27.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "argon2",
            "better-sqlite3-multiple-ciphers",
            "esbuild",
            "node-pty"
        ],
        "ignoredBuiltDependencies": [
            "cpu-features",
            "protobufjs",
            "ssh2"
        ]
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.0",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "eslint": "^10.0.1",
        "tailwindcss": "^4.2.0",
        "typescript": "^5.9.3",
        "vitest": "^3.2.4"
    },
    "dependencies": {
        "pg": "^8.18.0",
        "zod": "^3.24.2"
    }
}
