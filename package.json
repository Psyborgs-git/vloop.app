{
    "name": "orchestrator",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "description": "Host-level orchestrator daemon — manages containers, processes, AI agents, databases, and device access via secure WebSocket API.",
    "scripts": {
        "prepare": "node scripts/fix-pty-permissions.mjs 2>/dev/null || true",
        "build": "tsc --build",
        "dev": "node scripts/dev-restart.mjs",
        "dev:raw": "pnpm --filter @orch/orchestrator dev",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:integration": "vitest run --project integration",
        "lint": "eslint packages/",
        "clean": "tsc --build --clean && rm -rf packages/*/tsconfig.tsbuildinfo"
    },
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=10.0.0"
    },
    "packageManager": "pnpm@10.27.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "argon2",
            "better-sqlite3-multiple-ciphers",
            "esbuild",
            "node-pty"
        ],
        "ignoredBuiltDependencies": [
            "cpu-features",
            "protobufjs",
            "ssh2"
        ]
    },
    "devDependencies": {
        "@tailwindcss/vite": "^4.2.0",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "better-sqlite3-multiple-ciphers": "^12.6.2",
        "eslint": "^10.0.1",
        "tailwindcss": "^4.2.0",
        "typescript": "^5.9.3",
        "vitest": "^4.0.18"
    },
    "dependencies": {
        "@extism/extism": "2.0.0-rc13",
        "@msgpack/msgpack": "^3.1.3",
        "@types/diff": "^8.0.0",
        "diff": "^8.0.3",
        "pg": "^8.18.0",
        "reflect-metadata": "^0.2.2",
        "tsyringe": "^4.10.0",
        "zod": "^3.24.2"
    }
}
